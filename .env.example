# MODBUS TCP Service Environment Configuration
# Copy this file to .env and customize for your environment

# Application Settings
MODBUS_ENVIRONMENT=development
MODBUS_DEBUG=true

# Logging
MODBUS_LOG_LEVEL=INFO
MODBUS_LOG_FILE=/var/log/modbustcp/app.log

# MODBUS Settings
MODBUS_DEFAULT_TIMEOUT=3
MODBUS_DEFAULT_RETRY_COUNT=3
MODBUS_CONNECTION_POOL_SIZE=10

# Monitoring Settings
MODBUS_DEFAULT_POLL_INTERVAL=30
MODBUS_HEALTH_CHECK_INTERVAL=60
MODBUS_MAX_READING_AGE_HOURS=24

# Database Settings
DATABASE_URL=postgresql://modbustcp_user:password@localhost:5432/modbustcp_db
READING_STORE=postgresql  # postgresql or influxdb

# InfluxDB Settings (if using influxdb for readings)
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=modbustcp
INFLUXDB_BUCKET=readings

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=false

# Device Network Settings (examples)
MODBUS_HOST_SDM120=10.1.2.1
MODBUS_HOST_PM2510=10.1.2.1
MODBUS_HOST_XYMD02=10.1.2.1
MODBUS_PORT=502